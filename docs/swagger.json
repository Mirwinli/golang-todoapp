                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "Cписок задач",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Фільтрація задач по ID автора",
                        "name": "user_id",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Розмір сторінки з задачами",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Зміщення сторінки з задачами",
                        "name": "offset",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Список задач",
