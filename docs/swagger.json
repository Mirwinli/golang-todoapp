                            "$ref": "#/definitions/github_com_Mirwinli_golang-todoapp_internal_core_transport_http_response.ErrorResponse"
                        }
                    }
                }
            },
            "patch": {
                "description": "Оновлює інформацію вже в існуючій в системі задачі\n### Логіка оновлення полів (Three-state-logic)\n1. **Поле не передано**: `description` ігноруєтся, значення в БД не змінюєтся\n2. **Явно передано значення**: `description`: \"Вийти погуляти в 6:30 з собакою\" - змінюєьтся поле в БД\nОбмеження: `title` і `completed` не можуть бути виставденні null",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "tasks"
                ],
                "summary": "Оновити задачу",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID оновлюваної задачі",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "PatchTask тіло запиту",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_features_tasks_transport_http.PatchTaskRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Успішно змінена задача",
                        "schema": {
                            "$ref": "#/definitions/internal_features_tasks_transport_http.PatchTaskResponse"
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "schema": {
                            "$ref": "#/definitions/github_com_Mirwinli_golang-todoapp_internal_core_transport_http_response.ErrorResponse"
                        }
                    },
                    "404": {
                        "description": "Task not found",
                        "schema": {
                            "$ref": "#/definitions/github_com_Mirwinli_golang-todoapp_internal_core_transport_http_response.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/github_com_Mirwinli_golang-todoapp_internal_core_transport_http_response.ErrorResponse"
                        }
